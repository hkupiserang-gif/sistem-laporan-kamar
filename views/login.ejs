<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - Sistem Housekeeping</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/font-awesome@4.7.0/css/font-awesome.min.css">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            hotel: { dark: '#0F2B48', primary: '#2D5B7C', light: '#E8F0F5', accent: '#F2994A', success: '#27AE60', danger: '#E74C3C', neutral: '#F8FAFC' }
          }
        }
      }
    }
  </script>
</head>
<body class="bg-hotel-neutral min-h-screen flex items-center justify-center p-4">
  <div class="w-full max-w-md">
    <div class="bg-white rounded-lg shadow-lg overflow-hidden">
      <div class="bg-hotel-dark text-white p-6 text-center">
        <i class="fa fa-hotel text-4xl mb-2"></i>
        <h1 class="text-xl font-bold">Sistem Laporan Housekeeping</h1>
        <p class="text-sm opacity-90 mt-1">Masuk ke Sistem</p>
      </div>

      <div class="p-6">
        <% if (pesan) { %>
        <div class="mb-4 p-3 rounded bg-red-50 border border-red-200 text-red-700 text-sm text-center">
          <%= pesan %>
        </div>
        <% } %>

        <form method="POST" action="/login" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Username</label>
            <input type="text" name="username" required class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-hotel-primary">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Kata Sandi</label>
            <input type="password" name="password" required class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-hotel-primary">
          </div>
          <button type="submit" class="w-full bg-hotel-primary hover:bg-hotel-dark text-white font-medium py-2 rounded-md transition">Masuk</button>
        </form>
      </div>
    </div>
    <p class="text-center text-xs text-gray-500 mt-4">© 2026 Sistem Housekeeping Hotel</p>
  </div>
</body>
</html>
