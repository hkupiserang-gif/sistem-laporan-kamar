<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Horison Hotel - Login</title>
  <style>
    * {margin:0; padding:0; box-sizing:border-box; font-family:Arial, sans-serif;}
    body {background:#e8f0f8; display:flex; align-items:center; justify-content:center; min-height:100vh;}
    .login-box {background:white; padding:32px; border-radius:8px; box-shadow:0 2px 10px #0002; width:100%; max-width:400px; text-align:center;}
    .logo {font-size:28px; font-weight:bold; color:#002b5c; margin-bottom:8px;}
    .sub-logo {font-size:14px; color:#666; margin-bottom:24px;}
    h2 {font-size:18px; color:#222; margin-bottom:24px;}
    .pesan {padding:10px; border-radius:4px; margin-bottom:16px; font-size:14px;}
    .pesan.error {background:#ffe9e9; color:#b02020; border:1px solid #f8cccc;}
    .pesan.sukses {background:#e6f9ed; color:#157c38; border:1px solid #c8f0d6;}
    .form-group {margin-bottom:16px; text-align:left;}
    label {display:block; font-size:13px; color:#555; margin-bottom:6px;}
    input {width:100%; padding:10px; border:1px solid #ddd; border-radius:4px; font-size:14px;}
    button {width:100%; padding:11px; background:#004b8d; color:white; border:none; border-radius:4px; font-size:15px; cursor:pointer;}
    button:hover {background:#003a6e;}
  </style>
</head>
<body>
  <div class="login-box">
    <div class="logo">HORISON</div>
    <div class="sub-logo">TC-UPI SERANG<br>HOTEL & CONVENTION</div>
    <h2>Sistem Laporan Kamar<br><small>Masuk ke akun Anda</small></h2>

    <% if (pesan) { %>
      <div class="pesan <%= pesan.tipe %>"><%= pesan.teks %></div>
    <% } %>

    <form action="/login" method="POST">
      <div class="form-group">
        <label>Username</label>
        <input type="text" name="username" required>
      </div>
      <div class="form-group">
        <label>Kata Sandi</label>
        <input type="password" name="password" required>
      </div>
      <button type="submit">Masuk</button>
    </form>
  </div>
</body>
</html>
