<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - Sistem Hotel</title>
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#0F2B48">
  <link rel="icon" href="https://i.imgur.com/xQDZfY0.png">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: { hotel: { dark: '#0F2B48', primary: '#2D5B7C', light: '#E8F0F5' } }
        }
      }
    }
  </script>
</head>
<body class="bg-hotel-light min-h-screen flex items-center justify-center">
  <div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-md">
    <div class="text-center mb-6">
      <img src="https://i.imgur.com/xQDZfY0.png" alt="Logo Hotel" class="h-24 mx-auto mb-4">
      <h1 class="text-2xl font-bold text-hotel-dark">Sistem Laporan Kamar</h1>
      <p class="text-gray-500">Masuk ke akun Anda</p>
    </div>

    <% if (pesan) { %>
    <div class="mb-4 p-3 rounded bg-red-50 text-red-700 text-center text-sm"><%= pesan %></div>
    <% } %>

    <form action="/login" method="POST" class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Username</label>
        <input type="text" name="username" required class="w-full border border-gray-300 rounded p-2 focus:outline-none focus:ring-1 focus:ring-hotel-primary">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Kata Sandi</label>
        <input type="password" name="password" required class="w-full border border-gray-300 rounded p-2 focus:outline-none focus:ring-1 focus:ring-hotel-primary">
      </div>
      <button type="submit" class="w-full bg-hotel-primary hover:bg-hotel-dark text-white py-2 rounded">Masuk</button>
    </form>
  </div>
</body>
</html>
