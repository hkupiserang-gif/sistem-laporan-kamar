<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Panel Supervisor</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/font-awesome@4.7.0/css/font-awesome.min.css">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            hotel: { dark: '#0F2B48', primary: '#2D5B7C', light: '#E8F0F5', accent: '#F2994A', success: '#27AE60', danger: '#E74C3C', neutral: '#F8FAFC' }
          }
        }
      }
    }
  </script>
  <style>
    .status-radio {
      @apply w-4 h-4 cursor-pointer;
    }
    .status-label {
      @apply text-xs px-1.5 py-0.5 rounded border border-transparent hover:bg-gray-100 cursor-pointer;
    }
    input[type="radio"]:checked + .status-label {
      @apply bg-blue-100 border-blue-300 text-blue-800 font-medium;
    }
  </style>
</head>
<body class="bg-hotel-neutral min-h-screen">
  <div class="container mx-auto px-3 py-4 max-w-7xl">
    <!-- Header -->
    <div class="bg-white rounded-lg shadow-md mb-5 overflow-hidden">
      <div class="bg-hotel-dark text-white p-4 flex justify-between items-center">
        <div>
          <h1 class="text-lg font-bold">Panel Supervisor</h1>
          <p class="text-sm">Selamat datang, <%= user.nama %></p>
        </div>
        <div class="flex gap-2">
          <a href="/unduh" class="bg-hotel-accent text-white px-3 py-1.5 rounded text-sm flex items-center gap-1">
            <i class="fa fa-download"></i> Unduh Laporan
          </a>
          <a href="/logout" class="bg-red-500 text-white px-3 py-1.5 rounded text-sm flex items-center gap-1">
            <i class="fa fa-sign-out"></i> Keluar
          </a>
        </div>
      </div>
    </div>

    <!-- Form Pemberian Tugas -->
    <div class="bg-white rounded-lg shadow-md p-5 mb-5">
      <h2 class="text-base font-semibold text-hotel-dark mb-4 flex items-center gap-2">
        <i class="fa fa-tasks"></i> Berikan Tugas Kebersihan
      </h2>

      <% if (pesan) { %>
      <div class="mb-4 p-3 rounded text-sm <%= pesan.tipe === 'sukses' ? 'bg-green-50 text-green-700 border border-green-200' : 'bg-red-50 text-red-700 border border-red-200' %>">
        <%= pesan.teks %>
      </div>
      <% } %>

      <form method="POST" action="/tambah-tugas-banyak" class="space-y-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 items-end">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Tanggal</label>
            <input type="date" name="tanggal" value="<%= new Date().toISOString().split('T')[0] %>" required class="w-full border border-gray-300 rounded p-2 text-sm focus:outline-none focus:ring-1 focus:ring-hotel-primary">
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Pilih Roomboy</label>
            <select name="petugas" required class="w-full border border-gray-300 rounded p-2 text-sm focus:outline-none focus:ring-1 focus:ring-hotel-primary">
              <option value="">-- Pilih Nama --</option>
              <option value="Aslan">Aslan</option>
              <option value="Bila">Bila</option>
              <option value="Fika">Fika</option>
              <option value="Indah">Indah</option>
              <option value="Apri">Apri</option>
              <option value="Revan">Revan</option>
              <option value="Alwi">Alwi</option>
              <option value="Ajril">Ajril</option>
            </select>
          </div>

          <div>
            <button type="submit" class="w-full bg-hotel-primary hover:bg-hotel-dark text-white font-medium py-2 rounded">
              <i class="fa fa-check-circle mr-1"></i> Berikan Tugas ke Kamar Terpilih
            </button>
          </div>
        </div>

        <!-- Keterangan Status -->
        <div class="mb-3 text-xs text-gray-600">
          <span class="font-medium">Status Kamar:</span>
          <span class="bg-green-100 px-2 rounded mx-1">VC</span> Bersih & Kosong |
          <span class="bg-blue-100 px-2 rounded mx-1">VCU</span> Vacant Clean Uncheck |
          <span class="bg-orange-100 px-2 rounded mx-1">VD</span> Kotor & Kosong |
          <span class="bg-cyan-100 px-2 rounded mx-1">OC</span> Bersih & Terisi |
          <span class="bg-red-100 px-2 rounded mx-1">OD</span> Kotor & Terisi
        </div>

        <!-- Tombol Pilih Semua / Batalkan -->
        <div class="mb-3">
          <button type="button" onclick="pilihSemua()" class="text-sm text-hotel-primary hover:underline mr-4">✓ Pilih Semua Kamar</button>
          <button type="button" onclick="batalPilih()" class="text-sm text-gray-600 hover:underline">✗ Batalkan Pilihan</button>
        </div>

        <!-- Tabel Daftar Semua Kamar -->
        <div class="overflow-x-auto">
          <table class="w-full text-sm border-collapse">
            <thead>
              <tr class="bg-hotel-light">
                <th class="border border-gray-200 p-2 text-center w-12">Pilih</th>
                <th class="border border-gray-200 p-2 text-left">Nomor Kamar</th>
                <th class="border border-gray-200 p-2 text-left">Lantai</th>
                <th class="border border-gray-200 p-2 text-left">Tipe Kamar</th>
                <th class="border border-gray-200 p-2 text-center">Status Awal</th>
                <th class="border border-gray-200 p-2 text-left">Diberikan Kepada</th>
                <th class="border border-gray-200 p-2 text-center">Status Pengerjaan</th>
              </tr>
            </thead>
            <tbody>
              <% daftarKamar.forEach(kamar => { %>
              <tr class="hover:bg-gray-50">
                <td class="border border-gray-200 p-2 text-center">
                  <input type="checkbox" name="kamar[]" value="<%= kamar.nomor %>" class="w-4 h-4 text-hotel-primary border-gray-300 rounded">
                </td>
                <td class="border border-gray-200 p-2 font-medium"><%= kamar.nomor %></td>
                <td class="border border-gray-200 p-2"><%= kamar.lantai %></td>
                <td class="border border-gray-200 p-2"><%= kamar.tipe_kamar %></td>
                <td class="border border-gray-200 p-2">
                  <div class="flex items-center justify-center gap-3">
                    <div class="flex items-center gap-1">
                      <input type="radio" name="status_<%= kamar.nomor %>" value="VC" id="vc_<%= kamar.nomor %>" <%= kamar.status === 'VC' || !kamar.status ? 'checked' : '' %> class="status-radio">
                      <label for="vc_<%= kamar.nomor %>" class="status-label">VC</label>
                    </div>
                    <div class="flex items-center gap-1">
                      <input type="radio" name="status_<%= kamar.nomor %>" value="VCU" id="vcu_<%= kamar.nomor %>" <%= kamar.status === 'VCU' ? 'checked' : '' %> class="status-radio">
                      <label for="vcu_<%= kamar.nomor %>" class="status-label">VCU</label>
                    </div>
                    <div class="flex items-center gap-1">
                      <input type="radio" name="status_<%= kamar.nomor %>" value="VD" id="vd_<%= kamar.nomor %>" <%= kamar.status === 'VD' ? 'checked' : '' %> class="status-radio">
                      <label for="vd_<%= kamar.nomor %>" class="status-label">VD</label>
                    </div>
                    <div class="flex items-center gap-1">
                      <input type="radio" name="status_<%= kamar.nomor %>" value="OC" id="oc_<%= kamar.nomor %>" <%= kamar.status === 'OC' ? 'checked' : '' %> class="status-radio">
                      <label for="oc_<%= kamar.nomor %>" class="status-label">OC</label>
                    </div>
                    <div class="flex items-center gap-1">
                      <input type="radio" name="status_<%= kamar.nomor %>" value="OD" id="od_<%= kamar.nomor %>" <%= kamar.status === 'OD' ? 'checked' : '' %> class="status-radio">
                      <label for="od_<%= kamar.nomor %>" class="status-label">OD</label>
                    </div>
                  </div>
                </td>
                <td class="border border-gray-200 p-2"><%= kamar.petugas %></td>
                <td class="border border-gray-200 p-2 text-center font-medium">
                  <% if (kamar.statusProses === '✅ Selesai') { %>
                    <span class="text-green-600"><%= kamar.statusProses %></span>
                  <% } else if (kamar.statusProses === '⏳ Sedang Dikerjakan') { %>
                    <span class="text-orange-500"><%= kamar.statusProses %></span>
                  <% } else if (kamar.statusProses === '📝 Belum Dimulai') { %>
                    <span class="text-blue-500"><%= kamar.statusProses %></span>
                  <% } else { %>
                    <span class="text-gray-500"><%= kamar.statusProses %></span>
                  <% } %>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </form>
    </div>
  </div>

  <!-- Script Pilih Semua / Batalkan -->
  <script>
    function pilihSemua() {
      document.querySelectorAll('input[name="kamar[]"]').forEach(cb => cb.checked = true);
    }
    function batalPilih() {
      document.querySelectorAll('input[name="kamar[]"]').forEach(cb => cb.checked = false);
    }
  </script>
</body>
</html>
