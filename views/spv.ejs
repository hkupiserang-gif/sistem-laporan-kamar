<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Panel Supervisor</title>
  <style>
    body{font-family:Arial; max-width:800px; margin:20px auto; padding:0 15px; background:#f8f9fa;}
    .kotak{background:white; padding:15px; margin:15px 0; border-radius:6px; box-shadow:0 1px 3px #0002;}
    table{width:100%; border-collapse:collapse; margin-top:10px;}
    th,td{border:1px solid #ddd; padding:8px; text-align:left;}
    th{background:#f1f1f1;}
    button, a{padding:7px 12px; border:none; border-radius:4px; text-decoration:none; font-weight:bold; cursor:pointer;}
    .biru{background:#2980b9; color:white;}
    .hijau{background:#27ae60; color:white;}
    .merah{background:#e74c3c; color:white; float:right;}
  </style>
</head>
<body>
  <div class="kotak">
    <h3>Panel Supervisor</h3>
    <a href="/unduh" class="hijau">⬇️ Unduh Laporan</a>
    <a href="/" class="merah">Keluar</a>
  </div>

  <div class="kotak">
    <h4>Tambah Tugas</h4>
    <form method="POST" action="/tambah-tugas" style="display:flex; gap:10px; flex-wrap:wrap; align-items:flex-end;">
      <div>
        <label>Tanggal</label><br>
        <input type="date" name="tanggal" required>
      </div>
      <div>
        <label>Kamar</label><br>
        <input type="text" name="kamar" placeholder="101" required>
      </div>
      <div>
        <label>Petugas</label><br>
        <select name="petugas" required>
          <option value="Petugas Kamar">Petugas Kamar</option>
        </select>
      </div>
      <div>
        <label>Status Awal</label><br>
        <select name="status" required>
          <option value="VC">VC</option>
          <option value="VD">VD</option>
          <option value="OC">OC</option>
          <option value="OD">OD</option>
        </select>
      </div>
      <button type="submit" class="biru">Simpan</button>
    </form>
  </div>

  <div class="kotak">
    <h4>Daftar Tugas Hari Ini</h4>
    <% if (tugas.length < 1) { %>
      <p style="text-align:center; color:#666;">Belum ada tugas</p>
    <% } else { %>
      <table>
        <tr><th>Tanggal</th><th>Kamar</th><th>Petugas</th><th>Status</th><th>Selesai</th></tr>
        <% tugas.forEach(t => { %>
        <tr>
          <td><%= t.tanggal %></td>
          <td><%= t.kamar %></td>
          <td><%= t.petugas %></td>
          <td><%= t.status_awal %></td>
          <td><%= t.selesai ? '✅ Ya' : '❌ Belum' %></td>
        </tr>
        <% }) %>
      </table>
    <% } %>
  </div>
</body>
</html>
