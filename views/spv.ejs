<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Panel Supervisor</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/font-awesome@4.7.0/css/font-awesome.min.css">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            hotel: { dark: '#0F2B48', primary: '#2D5B7C', light: '#E8F0F5', accent: '#F2994A', success: '#27AE60', danger: '#E74C3C', neutral: '#F8FAFC' }
          }
        }
      }
    }
  </script>
</head>
<body class="bg-hotel-neutral min-h-screen">
  <div class="container mx-auto px-3 py-4 max-w-7xl">
    <div class="bg-white rounded-lg shadow-md mb-5 overflow-hidden">
      <div class="bg-hotel-dark text-white p-4 flex justify-between items-center">
        <div>
          <h1 class="text-lg font-bold">Panel Supervisor</h1>
          <p class="text-sm">Selamat datang, <%= user.nama %></p>
        </div>
        <div class="flex gap-2">
          <a href="/unduh" class="bg-hotel-accent text-white px-3 py-1 rounded text-sm"><i class="fa fa-download"></i> Unduh Laporan</a>
          <a href="/logout" class="bg-red-500 text-white px-3 py-1 rounded text-sm"><i class="fa fa-sign-out"></i> Keluar</a>
        </div>
      </div>
    </div>
    <div class="bg-white rounded-lg shadow-md mb-5 p-5">
      <h2 class="text-base font-semibold text-hotel-dark mb-4">Berikan Tugas Harian</h2>
      <form method="POST" action="/tambah-tugas" class="grid grid-cols-1 sm:grid-cols-5 gap-3">
        <div>
          <label class="text-sm text-gray-600">Tanggal</label>
          <input type="date" name="tanggal" value="<%= new Date().toISOString().split('T')[0] %>" required class="w-full border p-2 rounded">
        </div>
        <div>
          <label class="text-sm text-gray-600">Nomor Kamar</label>
          <input type="text" name="kamar" placeholder="Contoh: 201" required class="w-full border p-2 rounded">
        </div>
        <div>
          <label class="text-sm text-gray-600">Petugas</label>
          <select name="petugas" required class="w-full border p-2 rounded">
            <option value="Aslan">Aslan</option>
            <option value="Bila">Bila</option>
            <option value="Fika">Fika</option>
            <option value="Indah">Indah</option>
            <option value="Apri">Apri</option>
            <option value="Revan">Revan</option>
            <option value="Alwi">Alwi</option>
            <option value="Ajril">Ajril</option>
          </select>
        </div>
        <div>
          <label class="text-sm text-gray-600">Status Awal</label>
          <select name="status_awal" required class="w-full border p-2 rounded">
            <option value="VC">VC - Bersih Kosong</option>
            <option value="VD">VD - Kotor Kosong</option>
            <option value="OC">OC - Bersih Terisi</option>
            <option value="OD">OD - Kotor Terisi</option>
          </select>
        </div>
        <div class="self-end">
          <button type="submit" class="w-full bg-hotel-primary text-white p-2 rounded">Simpan</button>
        </div>
      </form>
    </div>
    <div class="bg-white rounded-lg shadow-md p-5 overflow-x-auto">
      <h2 class="text-base font-semibold text-hotel-dark mb-3">Daftar Tugas Hari Ini</h2>
      <% if (tugas.length > 0) { %>
      <table class="w-full border-collapse text-sm">
        <thead>
          <tr class="bg-hotel-light">
            <th class="border p-2">Tanggal</th>
            <th class="border p-2">Kamar</th>
            <th class="border p-2">Petugas</th>
            <th class="border p-2">Status</th>
          </tr>
        </thead>
        <tbody>
          <% tugas.forEach(item => { %>
          <tr class="hover:bg-gray-50">
            <td class="border p-2"><%= item.tanggal %></td>
            <td class="border p-2"><%= item.kamar %></td>
            <td class="border p-2"><%= item.petugas %></td>
            <td class="border p-2 text-center">
              <%= item.selesai ? '<span class="text-green-600">✅ Selesai</span>' : '<span class="text-orange-500">⏳ Belum</span>' %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } else { %>
      <p class="text-center text-gray-500 py-8">Belum ada tugas</p>
      <% } %>
    </div>
  </div>
</body>
</html>
