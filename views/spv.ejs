<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel Supervisor - Horison Hotel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        body {
            background-color: #f8f9fa;
        }
        .sidebar {
            min-height: 100vh;
            background-color: #2c3e50;
            color: white;
        }
        .sidebar a {
            color: #ecf0f1;
            text-decoration: none;
            padding: 12px 15px;
            display: block;
            transition: 0.3s;
        }
        .sidebar a:hover, .sidebar a.active {
            background-color: #34495e;
            border-left: 4px solid #f39c12;
            padding-left: 11px;
        }
        .content {
            padding: 20px;
        }
        .status-badge {
            font-size: 0.85rem;
            font-weight: 500;
        }
        .ra-header {
            background-color: #f1f5f9;
            padding: 8px 12px;
            border-radius: 4px;
            margin: 15px 0 8px;
            font-weight: bold;
            color: #2c3e50;
        }
        .empty-state {
            padding: 3rem;
            text-align: center;
            color: #6c757d;
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <div class="col-md-2 sidebar p-0">
                <div class="p-3 text-center border-bottom border-secondary">
                    <h5>HORISON HOTEL</h5>
                    <small>Panel Supervisor</small>
                </div>
                <nav>
                    <a href="/spv" class="active"><i class="bi bi-house-door me-2"></i>Beranda</a>
                    <% if (daftarBelumDibagikan && daftarBelumDibagikan.length > 0) { %>
                    <a href="#belum"><i class="bi bi-list-check me-2"></i>Belum Dibagikan</a>
                    <% } %>
                    <a href="#sudah"><i class="bi bi-person-check me-2"></i>Sudah Dibagikan</a>
                    <a href="#permintaan"><i class="bi bi-clipboard-data me-2"></i>Permintaan Tamu</a>
                    <a href="/logout" class="text-danger mt-3"><i class="bi bi-box-arrow-right me-2"></i>Keluar</a>
                </nav>
                <div class="position-absolute bottom-0 p-3 w-100 border-top border-secondary">
                    <small>Login sebagai: <strong><%= user.nama %></strong></small>
                </div>
            </div>

            <!-- Konten Utama -->
            <div class="col-md-10 content">
                <!-- Notifikasi Pesan -->
                <% if (pesan) { %>
                <div class="alert <%= pesan.tipe === 'sukses' ? 'alert-success' : 'alert-danger' %> alert-dismissible fade show" role="alert">
                    <%= pesan.teks %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Tutup"></button>
                </div>
                <% } %>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3>Daftar Kontrol Kamar & Tugas</h3>
                    <div class="text-muted">
                        <i class="bi bi-calendar me-1"></i> Tanggal: <%= cariTanggal %>
                    </div>
                </div>

                <!-- Filter Tanggal & Unduh Laporan -->
                <div class="card mb-4 shadow-sm">
                    <div class="card-body">
                        <form action="/spv" method="GET" class="row g-3 align-items-center">
                            <div class="col-md-3">
                                <label class="form-label">Pilih Tanggal</label>
                                <input type="date" name="tanggal" class="form-control" value="<%= cariTanggal %>" required>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Cari Kamar</label>
                                <input type="text" name="kamar" class="form-control" placeholder="Contoh: 201" value="<%= cariKamar %>">
                            </div>
                            <div class="col-md-2">
                                <label class="form-label d-block">&nbsp;</label>
                                <button type="submit" class="btn btn-primary w-100"><i class="bi bi-search me-1"></i> Tampilkan</button>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label d-block">&nbsp;</label>
                                <a href="/unduh-pdf?tanggal=<%= cariTanggal %>" class="btn btn-danger w-100" target="_blank">
                                    <i class="bi bi-file-pdf me-1"></i> Unduh PDF
                                </a>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label d-block">&nbsp;</label>
                                <a href="/unduh-excel?tanggal=<%= cariTanggal %>" class="btn btn-success w-100">
                                    <i class="bi bi-file-excel me-1"></i> Unduh Excel
                                </a>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- ✅ BAGIAN BELUM DIBAGIKAN (HANYA MUNCUL JIKA ADA) -->
                <% if (daftarBelumDibagikan && daftarBelumDibagikan.length > 0) { %>
                <div id="belum" class="card shadow-sm mb-5">
                    <div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Daftar Kamar Belum Dibagikan</h5>
                        <button class="btn btn-sm btn-light" data-bs-toggle="modal" data-bs-target="#modalBagikan">
                            <i class="bi bi-plus-circle me-1"></i> Bagikan Tugas Baru
                        </button>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-striped table-bordered table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>No</th>
                                        <th>Kamar</th>
                                        <th>Lantai</th>
                                        <th>Status Awal</th>
                                        <th>Status Pekerjaan</th>
                                        <th>Aksi</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% daftarBelumDibagikan.forEach((tugas, idx) => { %>
                                    <tr>
                                        <td><%= idx + 1 %></td>
                                        <td><strong><%= tugas.kamar %></strong></td>
                                        <td><%= tugas.lantai %></td>
                                        <td>
                                            <% if (tugas.status_awal === 'VD') { %>
                                                <span class="badge bg-secondary status-badge">VD - Kotor Kosong</span>
                                            <% } else if (tugas.status_awal === 'VC') { %>
                                                <span class="badge bg-success status-badge">VC - Bersih Kosong</span>
                                            <% } else if (tugas.status_awal === 'VCU') { %>
                                                <span class="badge bg-info text-dark status-badge">VCU - Belum Cek</span>
                                            <% } else if (tugas.status_awal === 'OD') { %>
                                                <span class="badge bg-warning text-dark status-badge">OD - Kotor Terisi</span>
                                            <% } else if (tugas.status_awal === 'OC') { %>
                                                <span class="badge bg-primary status-badge">OC - Bersih Terisi</span>
                                            <% } else if (tugas.status_awal === 'OM') { %>
                                                <span class="badge bg-dark status-badge">OM - Perawatan</span>
                                            <% } else if (tugas.status_awal === 'OOO') { %>
                                                <span class="badge bg-danger status-badge">OOO - Tidak Terpakai</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <span class="badge bg-secondary">Belum Dibagikan</span>
                                        </td>
                                        <td>
                                            <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#modalBagikan">
                                                <i class="bi bi-share me-1"></i> Bagikan
                                            </button>
                                        </td>
                                    </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <% } %>

                <!-- ✅ BAGIAN SUDAH DIBAGIKAN (PER PETUGAS) -->
                <div id="sudah" class="card shadow-sm mb-5">
                    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-person-check me-2"></i>Daftar Tugas Sudah Dibagikan</h5>
                        <button class="btn btn-sm btn-light" data-bs-toggle="modal" data-bs-target="#modalBagikan">
                            <i class="bi bi-plus-circle me-1"></i> Bagikan Tugas Baru
                        </button>
                    </div>
                    <div class="card-body p-3">
                        <% 
                        // Filter hanya data kamar yang valid
                        const kamarValid = {};
                        if (daftarSudahDibagikan) {
                            Object.keys(daftarSudahDibagikan).forEach(ra => {
                                const daftar = daftarSudahDibagikan[ra].filter(t => t.kamar && t.lantai);
                                if (daftar.length > 0) kamarValid[ra] = daftar;
                            });
                        }
                        %>
                        <% if (Object.keys(kamarValid).length === 0) { %>
                            <div class="empty-state">
                                <i class="bi bi-clipboard-x fs-1 mb-3 d-block"></i>
                                <h5>Belum ada tugas yang dibagikan hari ini</h5>
                                <p class="mb-0">Klik tombol <strong>Bagikan Tugas Baru</strong> untuk memulai pembagian tugas ke petugas</p>
                            </div>
                        <% } else { %>
                            <% Object.keys(kamarValid).forEach(namaRA => { %>
                                <div class="ra-header">👤 Petugas: <%= namaRA %></div>
                                <div class="table-responsive mb-4">
                                    <table class="table table-striped table-bordered table-hover mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th>No</th>
                                                <th>Kamar</th>
                                                <th>Lantai</th>
                                                <th>Status Awal</th>
                                                <th>Jam Masuk</th>
                                                <th>Jam Selesai</th>
                                                <th>Status Pekerjaan</th>
                                                <th>Aksi</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% kamarValid[namaRA].forEach((tugas, idx) => { %>
                                            <tr>
                                                <td><%= idx + 1 %></td>
                                                <td><strong><%= tugas.kamar %></strong></td>
                                                <td><%= tugas.lantai %></td>
                                                <td>
                                                    <% if (tugas.status_awal === 'VD') { %>
                                                        <span class="badge bg-secondary status-badge">VD - Kotor Kosong</span>
                                                    <% } else if (tugas.status_awal === 'VC') { %>
                                                        <span class="badge bg-success status-badge">VC - Bersih Kosong</span>
                                                    <% } else if (tugas.status_awal === 'VCU') { %>
                                                        <span class="badge bg-info text-dark status-badge">VCU - Belum Cek</span>
                                                    <% } else if (tugas.status_awal === 'OD') { %>
                                                        <span class="badge bg-warning text-dark status-badge">OD - Kotor Terisi</span>
                                                    <% } else if (tugas.status_awal === 'OC') { %>
                                                        <span class="badge bg-primary status-badge">OC - Bersih Terisi</span>
                                                    <% } else if (tugas.status_awal === 'OM') { %>
                                                        <span class="badge bg-dark status-badge">OM - Perawatan</span>
                                                    <% } else if (tugas.status_awal === 'OOO') { %>
                                                        <span class="badge bg-danger status-badge">OOO - Tidak Terpakai</span>
                                                    <% } %>
                                                </td>
                                                <td><%= tugas.waktu_masuk || '-' %></td>
                                                <td><%= tugas.waktu_keluar || '-' %></td>
                                                <td>
                                                    <% if (tugas.siap_dicek === 1) { %>
                                                        <span class="badge bg-success">✅ SIAP CEK</span>
                                                    <% } else if (tugas.selesai === 1) { %>
                                                        <span class="badge bg-primary">Selesai</span>
                                                    <% } else { %>
                                                        <span class="badge bg-warning text-dark">Dibagikan</span>
                                                    <% } %>
                                                </td>
                                                <td>
                                                    <button class="btn btn-sm btn-warning" data-bs-toggle="modal" data-bs-target="#modalRevisi_<%= namaRA.replace(/\s/g,'') %>_<%= tugas.kamar %>">
                                                        <i class="bi bi-pencil-square me-1"></i> Revisi
                                                    </button>
                                                </td>
                                            </tr>

                                            <!-- Modal Revisi -->
                                            <div class="modal fade" id="modalRevisi_<%= namaRA.replace(/\s/g,'') %>_<%= tugas.kamar %>" tabindex="-1" aria-labelledby="modalRevisiLabel_<%= namaRA.replace(/\s/g,'') %>_<%= tugas.kamar %>" aria-hidden="true">
                                                <div class="modal-dialog">
                                                    <div class="modal-content">
                                                        <form action="/tambah-tugas" method="POST">
                                                            <div class="modal-header bg-warning">
                                                                <h5 class="modal-title" id="modalRevisiLabel_<%= namaRA.replace(/\s/g,'') %>_<%= tugas.kamar %>">
                                                                    <i class="bi bi-pencil-square me-2"></i>Revisi Tugas Kamar <%= tugas.kamar %>
                                                                </h5>
                                                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Tutup"></button>
                                                            </div>
                                                            <div class="modal-body">
                                                                <input type="hidden" name="tanggal" value="<%= cariTanggal %>">
                                                                <input type="hidden" name="kamar" value="<%= tugas.kamar %>">

                                                                <div class="mb-3">
                                                                    <label class="form-label">Nama Petugas</label>
                                                                    <select name="petugas" class="form-select" required>
                                                                        <% daftarRA.forEach(ra => { %>
                                                                            <option value="<%= ra.nama %>" <%= ra.nama === tugas.petugas ? 'selected' : '' %>>
                                                                                <%= ra.nama %>
                                                                            </option>
                                                                        <% }) %>
                                                                    </select>
                                                                </div>

                                                                <div class="mb-3">
                                                                    <label class="form-label">Status Awal Kamar</label>
                                                                    <select name="status_awal" class="form-select" required>
                                                                        <option value="VD" <%= tugas.status_awal === 'VD' ? 'selected' : '' %>>VD - Vacant Dirty</option>
                                                                        <option value="VC" <%= tugas.status_awal === 'VC' ? 'selected' : '' %>>VC - Vacant Clean</option>
                                                                        <option value="VCU" <%= tugas.status_awal === 'VCU' ? 'selected' : '' %>>VCU - Vacant Clean Unchecked</option>
                                                                        <option value="OD" <%= tugas.status_awal === 'OD' ? 'selected' : '' %>>OD - Occupied Dirty</option>
                                                                        <option value="OC" <%= tugas.status_awal === 'OC' ? 'selected' : '' %>>OC - Occupied Clean</option>
                                                                        <option value="OM" <%= tugas.status_awal === 'OM' ? 'selected' : '' %>>OM - Occupied Maintenance</option>
                                                                        <option value="OOO" <%= tugas.status_awal === 'OOO' ? 'selected' : '' %>>OOO - Out of Order</option>
                                                                    </select>
                                                                </div>
                                                            </div>
                                                            <div class="modal-footer">
                                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                                                                <button type="submit" class="btn btn-primary">Simpan Perubahan</button>
                                                            </div>
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>
                                            <% }) %>
                                        </tbody>
                                    </table>
                                </div>
                            <% }) %>
                        <% } %>
                    </div>
                </div>

                <!-- Modal Bagikan Tugas Baru -->
                <div class="modal fade" id="modalBagikan" tabindex="-1" aria-labelledby="modalBagikanLabel" aria-hidden="true">
                    <div class="modal-dialog modal-lg">
                        <div class="modal-content">
                            <form action="/tambah-tugas" method="POST">
                                <div class="modal-header bg-primary text-white">
                                    <h5 class="modal-title" id="modalBagikanLabel">
                                        <i class="bi bi-plus-circle me-2"></i>Bagikan Tugas Kebersihan
                                    </h5>
                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Tutup"></button>
                                </div>
                                <div class="modal-body">
                                    <input type="hidden" name="tanggal" value="<%= cariTanggal %>">

                                    <div class="mb-3">
                                        <label class="form-label">Pilih Petugas</label>
                                        <select name="petugas" class="form-select" required>
                                            <option value="">-- Pilih Nama Petugas --</option>
                                            <% daftarRA.forEach(ra => { %>
                                                <option value="<%= ra.nama %>"><%= ra.nama %></option>
                                            <% }) %>
                                        </select>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Status Awal Kamar</label>
                                        <select name="status_awal" class="form-select" required>
                                            <option value="VD">VD - Vacant Dirty</option>
                                            <option value="VC">VC - Vacant Clean</option>
                                            <option value="VCU">VCU - Vacant Clean Unchecked</option>
                                            <option value="OD">OD - Occupied Dirty</option>
                                            <option value="OC">OC - Occupied Clean</option>
                                            <option value="OM">OM - Occupied Maintenance</option>
                                            <option value="OOO">OOO - Out of Order</option>
                                        </select>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Pilih Kamar yang Akan Dibagikan</label>
                                        <div class="border p-3 rounded" style="max-height: 350px; overflow-y: auto;">
                                            <% 
                                            // Cek kamar yang sudah dibagikan
                                            const kamarSudah = Object.values(kamarValid).flat().map(t => t.kamar);
                                            Object.keys(kamarPerLantai || {}).forEach(lantai => {
                                                const daftarKamar = kamarPerLantai[lantai].filter(k => k && k.nomor_kamar);
                                                if (daftarKamar.length === 0) return;
                                            %>
                                                <div class="mb-3">
                                                    <h6 class="text-primary border-bottom pb-1"><%= lantai %></h6>
                                                    <div class="row g-2">
                                                        <% daftarKamar.forEach(kamar => { 
                                                            const sudah = kamarSudah.includes(kamar.nomor_kamar);
                                                        %>
                                                            <div class="col-md-3 col-sm-4">
                                                                <div class="form-check p-2 border rounded <%= sudah ? 'bg-light' : '' %>">
                                                                    <input class="form-check-input" type="checkbox" name="kamar" value="<%= kamar.nomor_kamar %>" id="kamar_<%= kamar.nomor_kamar %>" <%= sudah ? 'disabled' : '' %>>
                                                                    <label class="form-check-label w-100 <%= sudah ? 'text-muted' : '' %>" for="kamar_<%= kamar.nomor_kamar %>">
                                                                        <%= kamar.nomor_kamar %>
                                                                        <% if (sudah) { %>
                                                                            <small class="d-block text-success">✓ Sudah Dibagikan</small>
                                                                        <% } %>
                                                                    </label>
                                                                </div>
                                                            </div>
                                                        <% }) %>
                                                    </div>
                                                </div>
                                            <% }) %>
                                        </div>
                                        <small class="text-muted">* Hanya kamar terdaftar yang tersedia untuk dipilih</small>
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                                    <button type="submit" class="btn btn-primary">Bagikan Tugas</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Bagian Daftar Permintaan Tamu -->
                <div id="permintaan" class="card shadow-sm">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0"><i class="bi bi-clipboard-data me-2"></i>Daftar Permintaan Tamu</h5>
                    </div>
                    <div class="card-body p-0">
                        <% if (!daftarPermintaan || daftarPermintaan.length === 0) { %>
                            <div class="p-4 text-center text-muted">
                                Belum ada permintaan tamu untuk hari ini.
                            </div>
                        <% } else { %>
                        <div class="table-responsive">
                            <table class="table table-striped table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>No</th>
                                        <th>Kamar</th>
                                        <th>Jenis Permintaan</th>
                                        <th>Keterangan</th>
                                        <th>Waktu</th>
                                        <th>Status</th>
                                        <th>Dibuat Oleh</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% daftarPermintaan.forEach((p, i) => { %>
                                    <tr>
                                        <td><%= i + 1 %></td>
                                        <td><%= p.nomor_kamar %></td>
                                        <td><%= p.jenis_permintaan %></td>
                                        <td><%= p.keterangan || '-' %></td>
                                        <td><%= p.waktu_masuk %></td>
                                        <td>
                                            <% if (p.status === 'Dipinjam Tamu') { %>
                                                <span class="badge bg-warning text-dark">Dipinjam</span>
                                            <% } else if (p.status === 'Dikembalikan') { %>
                                                <span class="badge bg-success">Dikembalikan</span>
                                            <% } else { %>
                                                <span class="badge bg-secondary"><%= p.status %></span>
                                            <% } %>
                                        </td>
                                        <td><%= p.dibuat_oleh %></td>
                                    </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
