<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Panel Supervisor</title>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; font-family:Arial; }
    body { background:#f8f9fa; max-width:900px; margin:0 auto; padding:20px; }
    .card { background:white; border-radius:10px; padding:20px; margin-bottom:15px; box-shadow:0 1px 5px rgba(0,0,0,0.1); }
    h2 { color:#2c3e50; margin-bottom:15px; font-size:20px; }
    h3 { color:#34495e; margin-bottom:12px; font-size:18px; }
    table { width:100%; border-collapse:collapse; margin-top:15px; font-size:14px; }
    th, td { border:1px solid #ddd; padding:8px; text-align:left; }
    th { background:#f1f1f1; font-weight:bold; }
    button, a.btn { padding:8px 15px; border:none; border-radius:6px; cursor:pointer; font-weight:bold; font-size:14px; text-decoration:none; display:inline-block; margin-right:8px; margin-bottom:8px; }
    .btn-biru { background:#2980b9; color:white; }
    .btn-hijau { background:#27ae60; color:white; }
    .btn-merah { background:#e74c3c; color:white; float:right; }
    .baris { display:flex; gap:10px; flex-wrap:wrap; margin-bottom:10px; }
    .baris > div { flex:1; min-width:130px; }
    label { display:block; margin-bottom:4px; font-size:14px; }
    input, select { width:100%; padding:8px; border:1px solid #ddd; border-radius:4px; }
  </style>
</head>
<body>
  <div class="card">
    <h2>👨‍💼 Panel Supervisor</h2>
    <a href="/unduh" class="btn-hijau">⬇️ Unduh Semua Laporan (CSV/Excel)</a>
    <a href="/" class="btn-merah">Keluar</a>
  </div>

  <div class="card">
    <h3>➕ Berikan Tugas Harian</h3>
    <form method="POST" action="/tambah-tugas">
      <div class="baris">
        <div>
          <label>Tanggal</label>
          <input type="date" name="tanggal" required>
        </div>
        <div>
          <label>Nomor Kamar</label>
          <input type="text" name="kamar" placeholder="Contoh: 101" required>
        </div>
        <div>
          <label>Petugas</label>
          <select name="petugas" required>
            <option value="Petugas Kamar">Petugas Kamar</option>
          </select>
        </div>
        <div>
          <label>Status Awal</label>
          <select name="status" required>
            <option value="VC">VC - Bersih Kosong</option>
            <option value="VD">VD - Kotor Kosong</option>
            <option value="OC">OC - Bersih Terisi</option>
            <option value="OD">OD - Kotor Terisi</option>
          </select>
        </div>
      </div>
      <button type="submit" class="btn-biru">Simpan Tugas</button>
    </form>
  </div>

  <div class="card">
    <h3>📋 Daftar Tugas Hari Ini</h3>
    <% if (tugas.length === 0) { %>
      <p style="text-align:center; color:#666; padding:15px;">Belum ada tugas yang dibuat</p>
    <% } else { %>
      <table>
        <thead>
          <tr><th>Tanggal</th><th>Kamar</th><th>Petugas</th><th>Status Awal</th><th>Selesai</th></tr>
        </thead>
        <tbody>
          <% tugas.forEach(t => { %>
            <tr>
              <td><%= t.tanggal %></td>
              <td><%= t.kamar %></td>
              <td><%= t.petugas %></td>
              <td><%= t.status_awal %></td>
              <td><%= t.selesai ? '✅ Ya' : '❌ Belum' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</body>
</html>
