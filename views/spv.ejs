<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Panel Supervisor - Horison Hotel</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
  <style>
    body { background-color: #f8f9fa; font-size: 0.9rem; }
    .sidebar { min-height: 100vh; background-color: #2c3e50; color: white; }
    .sidebar a { color: #ecf0f1; text-decoration: none; padding: 12px 15px; display: block; border-left: 3px solid transparent; }
    .sidebar a:hover, .sidebar a.active { background-color: #34495e; border-left: 3px solid #f39c12; }
    .content { padding: 25px; }
    .badge { font-size: 0.85rem; }
    .card { border-radius: 8px; box-shadow: 0 2px 6px rgba(0,0,0,0.08); margin-bottom: 20px; }
    .modal-lg { max-width: 900px; }
    .form-check-input:disabled + .form-check-label { opacity: 0.6; }
  </style>
</head>
<body>
<div class="container-fluid">
  <div class="row">
    <!-- Sidebar -->
    <div class="col-md-2 sidebar p-0">
      <div class="p-3 text-center border-bottom border-secondary">
        <h5>HORISON HOTEL</h5>
        <small>Panel Supervisor</small>
      </div>
      <nav>
        <a href="/spv" class="active"><i class="bi bi-house-door me-2"></i>Beranda</a>
        <a href="#tugas"><i class="bi bi-list-check me-2"></i>Daftar Tugas</a>
        <a href="#permintaan"><i class="bi bi-clipboard-data me-2"></i>Permintaan Tamu</a>
        <a href="/logout" class="text-danger mt-3"><i class="bi bi-box-arrow-right me-2"></i>Keluar</a>
      </nav>
      <div class="position-absolute bottom-0 p-3 w-100 border-top border-secondary">
        <small>Login sebagai: <strong><%= user.nama %></strong></small>
      </div>
    </div>

    <!-- Konten Utama -->
    <div class="col-md-10 content">
      <!-- Notifikasi -->
      <% if (pesan) { %>
      <div class="alert <%= pesan.tipe === 'sukses' ? 'alert-success' : 'alert-danger' %> alert-dismissible fade show mb-4" role="alert">
        <%= pesan.teks %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Tutup"></button>
      </div>
      <% } %>

      <div class="d-flex justify-content-between align-items-center mb-4">
        <h3>Daftar Kontrol Kamar & Tugas</h3>
        <div class="text-muted">
          <i class="bi bi-calendar me-1"></i> Tanggal: <%= cariTanggal %>
        </div>
      </div>

      <!-- Filter & Tombol Laporan -->
      <div class="card mb-4">
        <div class="card-body">
          <form action="/spv" method="GET" class="row g-3 align-items-end">
            <div class="col-md-2">
              <label class="form-label">Tanggal</label>
              <input type="date" name="tanggal" class="form-control" value="<%= cariTanggal %>" required>
            </div>
            <div class="col-md-2">
              <label class="form-label">Nama Petugas</label>
              <select name="petugas" class="form-select">
                <option value="">Semua Petugas</option>
                <% daftarRA.forEach(ra => { %>
                <option value="<%= ra.nama %>" <%= filterPetugas === ra.nama ? 'selected' : '' %>><%= ra.nama %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-2">
              <label class="form-label">Cari Kamar</label>
              <input type="text" name="kamar" class="form-control" placeholder="Contoh: 201" value="<%= cariKamar %>">
            </div>
            <div class="col-md-2">
              <button type="submit" class="btn btn-primary w-100"><i class="bi bi-search me-1"></i>Tampilkan</button>
            </div>
            <div class="col-md-2">
              <a href="/unduh-pdf-petugas?tanggal=<%= cariTanggal %>&petugas=<%= filterPetugas %>" class="btn btn-danger w-100" target="_blank">
                <i class="bi bi-file-pdf me-1"></i>Laporan Petugas
              </a>
            </div>
            <div class="col-md-2">
              <a href="/unduh-pdf-permintaan?tanggal=<%= cariTanggal %>" class="btn btn-warning w-100" target="_blank">
                <i class="bi bi-file-pdf me-1"></i>Laporan Permintaan
              </a>
            </div>
          </form>
        </div>
      </div>

      <!-- Daftar Tugas Kamar -->
      <div id="tugas" class="card mb-5">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
          <h5 class="mb-0">Daftar Tugas Kamar</h5>
          <button class="btn btn-sm btn-light" data-bs-toggle="modal" data-bs-target="#modalBagikan">
            <i class="bi bi-plus-circle me-1"></i>Bagikan Tugas Baru
          </button>
        </div>
        <div class="card-body p-0">
          <% if (daftarTugas.length === 0) { %>
            <div class="p-5 text-center text-muted">
              <i class="bi bi-clipboard-x fs-2 d-block mb-2"></i>
              Belum ada tugas yang dibagikan hari ini.
            </div>
          <% } else { %>
          <div class="table-responsive">
            <table class="table table-striped table-bordered table-hover mb-0">
              <thead>
                <tr>
                  <th>No</th>
                  <th>Kamar</th>
                  <th>Lantai</th>
                  <th>Status Awal</th>
                  <th>Petugas</th>
                  <th>Jam Masuk</th>
                  <th>Jam Keluar</th>
                  <th>Status Pekerjaan</th>
                  <th>Aksi</th>
                </tr>
              </thead>
              <tbody>
                <% daftarTugas.forEach((tugas, idx) => { %>
                <tr>
                  <td><%= idx + 1 %></td>
                  <td><strong><%= tugas.kamar %></strong></td>
                  <td><%= tugas.lantai %></td>
                  <td>
                    <% if (tugas.status_awal === 'VD') { %><span class="badge bg-secondary">VD - Kotor Kosong</span>
                    <% } else if (tugas.status_awal === 'VC') { %><span class="badge bg-success">VC - Bersih Kosong</span>
                    <% } else if (tugas.status_awal === 'VCU') { %><span class="badge bg-info text-dark">VCU - Belum Cek</span>
                    <% } else if (tugas.status_awal === 'OD') { %><span class="badge bg-warning text-dark">OD - Kotor Terisi</span>
                    <% } else if (tugas.status_awal === 'OC') { %><span class="badge bg-primary">OC - Bersih Terisi</span>
                    <% } else if (tugas.status_awal === 'OM') { %><span class="badge bg-dark">OM - Perbaikan</span>
                    <% } else if (tugas.status_awal === 'OOO') { %><span class="badge bg-danger">OOO - Tutup</span>
                    <% } %>
                  </td>
                  <td><%= tugas.petugas %></td>
                  <td><%= tugas.waktu_masuk %></td>
                  <td><%= tugas.waktu_keluar %></td>
                  <td>
                    <% if (tugas.selesai === 1) { %>
                      <span class="badge bg-success">Selesai</span>
                    <% } else { %>
                      <span class="badge bg-secondary">Belum Selesai</span>
                    <% } %>
                  </td>
                  <td>
                    <button class="btn btn-sm btn-warning" data-bs-toggle="modal" data-bs-target="#modalRevisi<%= idx %>">
                      <i class="bi bi-pencil-square me-1"></i>Revisi
                    </button>
                  </td>
                </tr>

                <!-- Modal Revisi -->
                <div class="modal fade" id="modalRevisi<%= idx %>" tabindex="-1" aria-labelledby="modalRevisiLabel<%= idx %>" aria-hidden="true">
                  <div class="modal-dialog">
                    <div class="modal-content">
                      <form action="/tambah-tugas" method="POST">
                        <div class="modal-header bg-warning text-dark">
                          <h5 class="modal-title">Revisi Tugas Kamar <%= tugas.kamar %></h5>
                          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Tutup"></button>
                        </div>
                        <div class="modal-body">
                          <input type="hidden" name="tanggal" value="<%= cariTanggal %>">
                          <input type="hidden" name="kamar" value="<%= tugas.kamar %>">
                          <div class="mb-3">
                            <label class="form-label">Nama Petugas</label>
                            <select name="petugas" class="form-select" required>
                              <% daftarRA.forEach(ra => { %>
                              <option value="<%= ra.nama %>" <%= tugas.petugas === ra.nama ? 'selected' : '' %>><%= ra.nama %></option>
                              <% }) %>
                            </select>
                          </div>
                          <div class="mb-3">
                            <label class="form-label">Status Awal Kamar</label>
                            <select name="status_awal" class="form-select" required>
                              <option value="VD" <%= tugas.status_awal === 'VD' ? 'selected' : '' %>>VD - Kotor Kosong</option>
                              <option value="VC" <%= tugas.status_awal === 'VC' ? 'selected' : '' %>>VC - Bersih Kosong</option>
                              <option value="VCU" <%= tugas.status_awal === 'VCU' ? 'selected' : '' %>>VCU - Bersih Belum Cek</option>
                              <option value="OD" <%= tugas.status_awal === 'OD' ? 'selected' : '' %>>OD - Kotor Terisi</option>
                              <option value="OC" <%= tugas.status_awal === 'OC' ? 'selected' : '' %>>OC - Bersih Terisi</option>
                              <option value="OM" <%= tugas.status_awal === 'OM' ? 'selected' : '' %>>OM - Perbaikan</option>
                              <option value="OOO" <%= tugas.status_awal === 'OOO' ? 'selected' : '' %>>OOO - Tutup Sementara</option>
                            </select>
                          </div>
                        </div>
                        <div class="modal-footer">
                          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                          <button type="submit" class="btn btn-primary">Simpan Perubahan</button>
                        </div>
                      </form>
                    </div>
                  </div>
                </div>
                <% }) %>
              </tbody>
            </table>
          </div>
          <% } %>
        </div>
      </div>

      <!-- Daftar Permintaan Tamu -->
      <div id="permintaan" class="card">
        <div class="card-header bg-warning text-dark">
          <h5 class="mb-0">Daftar Permintaan Tamu Hari Ini</h5>
        </div>
        <div class="card-body p-0">
          <% if (daftarPermintaan.length === 0) { %>
            <div class="p-5 text-center text-muted">
              <i class="bi bi-clipboard-check fs-2 d-block mb-2"></i>
              Belum ada permintaan dari tamu hari ini.
            </div>
          <% } else { %>
          <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
              <thead>
                <tr>
                  <th>No</th>
                  <th>Kamar</th>
                  <th>Jenis Permintaan</th>
                  <th>Keterangan</th>
                  <th>Waktu Masuk</th>
                  <th>Waktu Selesai</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% daftarPermintaan.forEach((p, idx) => { %>
                <tr>
                  <td><%= idx + 1 %></td>
                  <td><%= p.nomor_kamar %></td>
                  <td><%= p.jenis_permintaan %></td>
                  <td><%= p.keterangan || '-' %></td>
                  <td><%= p.waktu_masuk %></td>
                  <td><%= p.waktu_selesai || '-' %></td>
                  <td>
                    <% if (p.status === 'Dipinjam Tamu') { %>
                      <span class="badge bg-warning text-dark">Sedang Dipakai</span>
                    <% } else { %>
                      <span class="badge bg-success">Selesai</span>
                    <% } %>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Modal Bagikan Tugas Baru -->
<div class="modal fade" id="modalBagikan" tabindex="-1" aria-labelledby="modalBagikanLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <form action="/tambah-tugas" method="POST">
        <div class="modal-header bg-primary text-white">
          <h5 class="modal-title" id="modalBagikanLabel">Bagikan Tugas Kebersihan</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Tutup"></button>
        </div>
        <div class="modal-body">
          <input type="hidden" name="tanggal" value="<%= cariTanggal %>">

          <div class="mb-3">
            <label class="form-label">Pilih Petugas</label>
            <select name="petugas" class="form-select" required>
              <option value="">-- Pilih Petugas --</option>
              <% daftarRA.forEach(ra => { %>
              <option value="<%= ra.nama %>"><%= ra.nama %></option>
              <% }) %>
            </select>
          </div>

          <div class="mb-3">
            <label class="form-label">Status Awal Kamar</label>
            <select name="status_awal" class="form-select" required>
              <option value="VD">VD - Kotor Kosong</option>
              <option value="VC">VC - Bersih Kosong</option>
              <option value="VCU">VCU - Bersih Belum Cek</option>
              <option value="OD">OD - Kotor Terisi</option>
              <option value="OC">OC - Bersih Terisi</option>
              <option value="OM">OM - Perbaikan</option>
              <option value="OOO">OOO - Tutup Sementara</option>
            </select>
          </div>

          <hr>
          <h6 class="mb-3">Pilih Kamar Berdasarkan Lantai</h6>

          <% for (const lantai in kamarPerLantai) { %>
          <div class="mb-3">
            <h6 class="text-muted border-bottom pb-1"><%= lantai %></h6>
            <div class="row g-2">
              <% kamarPerLantai[lantai].forEach(k => { %>
              <div class="col-md-2 col-sm-3 col-4">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="kamar" value="<%= k.nomor_kamar %>" id="kamar_<%= k.nomor_kamar %>" <%= k.sudahAda ? 'disabled' : '' %>>
                  <label class="form-check-label" for="kamar_<%= k.nomor_kamar %>">
                    <%= k.nomor_kamar %> <%= k.sudahAda ? '(sudah ada)' : '' %>
                  </label>
                </div>
              </div>
              <% }) %>
            </div>
          </div>
          <% } %>

        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
          <button type="submit" class="btn btn-primary">Bagikan Tugas</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
