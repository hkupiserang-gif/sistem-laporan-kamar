              <button type="button" onclick="catatMasuk('<%= item.kamar %>')" id="btn_in_<%= item.kamar %>" class="btn-time <%= item.waktu_masuk ? 'btn-disabled' : 'btn-in' %>" <%= item.waktu_masuk ? 'disabled' : '' %>>IN</button>
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Waktu Keluar</label>
            <div class="flex items-center gap-2">
              <input type="text" name="waktu_keluar" id="keluar_<%= item.kamar %>" readonly placeholder="Belum dicatat" class="flex-1 border border-gray-300 rounded p-2 text-sm bg-gray-50" value="<%= item.waktu_keluar || '' %>">
              <button type="button" onclick="catatKeluar('<%= item.kamar %>')" id="btn_out_<%= item.kamar %>" class="btn-time <%= item.waktu_masuk && !item.waktu_keluar ? 'btn-out' : 'btn-disabled' %>" <%= !item.waktu_masuk || item.waktu_keluar ? 'disabled' : '' %>>OUT</button>
